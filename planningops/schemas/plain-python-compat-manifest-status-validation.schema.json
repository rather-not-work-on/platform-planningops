{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "planningops/schemas/plain-python-compat-manifest-status-validation.schema.json",
  "title": "PlanningOps Plain Python Compatibility Manifest Status Validation Report",
  "type": "object",
  "required": [
    "status_path",
    "schema_path",
    "output_path",
    "generated_at_utc",
    "verdict",
    "error_count",
    "warning_count",
    "errors",
    "warnings",
    "status_generated_at_utc",
    "status_output_path",
    "status_validation_output_path",
    "validation_output_path",
    "manifest_path",
    "resolved_guardrail_script_paths",
    "status_verdict",
    "status_ready",
    "status_next_step",
    "status_loop_guardrails_step_count"
  ],
  "properties": {
    "status_path": {
      "type": "string",
      "minLength": 1
    },
    "schema_path": {
      "type": "string",
      "minLength": 1
    },
    "output_path": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "error_count": {
      "type": "integer",
      "minimum": 0
    },
    "warning_count": {
      "type": "integer",
      "minimum": 0
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status_generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "status_output_path": {
      "type": "string",
      "minLength": 1
    },
    "status_validation_output_path": {
      "type": "string",
      "minLength": 1
    },
    "validation_output_path": {
      "type": "string",
      "minLength": 1
    },
    "manifest_path": {
      "type": "string",
      "minLength": 1
    },
    "resolved_guardrail_script_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status_verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "status_ready": {
      "type": "boolean"
    },
    "status_next_step": {
      "type": "string",
      "minLength": 1
    },
    "status_loop_guardrails_step_count": {
      "type": "integer",
      "minimum": 0
    },
    "canonical_loop_guardrails_step_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
