{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "planningops/schemas/plain-python-compat-manifest-status-bundle-status.schema.json",
  "title": "PlanningOps Plain Python Compatibility Manifest Status Bundle Status Report",
  "type": "object",
  "required": [
    "bundle_path",
    "resolved_status_bundle_path",
    "bundle_status_output_path",
    "bundle_status_validation_output_path",
    "bundle_validation_output_path",
    "generated_at_utc",
    "verdict",
    "ready",
    "next_step",
    "error_count",
    "warning_count",
    "errors",
    "warnings",
    "manifest_path",
    "resolved_guardrail_script_paths",
    "status_path",
    "status_validation_path",
    "bundle_status_verdict",
    "bundle_status_validation_verdict",
    "bundle_validation_verdict"
  ],
  "properties": {
    "bundle_path": {
      "type": "string",
      "minLength": 1
    },
    "resolved_status_bundle_path": {
      "type": "string",
      "minLength": 1
    },
    "bundle_status_output_path": {
      "type": "string",
      "minLength": 1
    },
    "bundle_status_validation_output_path": {
      "type": "string",
      "minLength": 1
    },
    "bundle_validation_output_path": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "ready": {
      "type": "boolean"
    },
    "next_step": {
      "type": "string",
      "minLength": 1
    },
    "error_count": {
      "type": "integer",
      "minimum": 0
    },
    "warning_count": {
      "type": "integer",
      "minimum": 0
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "manifest_path": {
      "type": "string",
      "minLength": 1
    },
    "resolved_guardrail_script_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status_path": {
      "type": "string",
      "minLength": 1
    },
    "status_validation_path": {
      "type": "string",
      "minLength": 1
    },
    "bundle_status_verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "bundle_status_validation_verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "bundle_validation_verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    }
  },
  "additionalProperties": false
}
