{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plan-execution-contract-v1",
  "title": "Plan Execution Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "execution_contract"
  ],
  "properties": {
    "execution_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_id",
        "plan_revision",
        "source_of_truth",
        "items"
      ],
      "properties": {
        "plan_id": {
          "type": "string",
          "minLength": 1
        },
        "plan_revision": {
          "type": "integer",
          "minimum": 1
        },
        "source_of_truth": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/item"
          }
        }
      }
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_item_id",
        "execution_order",
        "title",
        "target_repo",
        "component",
        "workflow_state",
        "loop_profile",
        "depends_on",
        "primary_output"
      ],
      "properties": {
        "plan_item_id": {
          "type": "string",
          "minLength": 1
        },
        "execution_order": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "target_repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "component": {
          "type": "string",
          "enum": [
            "planningops",
            "contracts",
            "provider_gateway",
            "observability_gateway",
            "runtime",
            "orchestrator"
          ]
        },
        "workflow_state": {
          "type": "string",
          "enum": [
            "backlog",
            "ready_contract",
            "ready_implementation",
            "in_progress",
            "review_gate",
            "blocked",
            "done"
          ]
        },
        "loop_profile": {
          "type": "string",
          "enum": [
            "l1_contract_clarification",
            "l2_simulation",
            "l3_implementation_tdd",
            "l4_integration_reconcile",
            "l5_recovery_replan"
          ]
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "uniqueItems": true
        },
        "primary_output": {
          "type": "string",
          "minLength": 1
        },
        "required_checks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}

