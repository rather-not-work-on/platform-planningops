{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "planningops/schemas/plain-python-compat-manifest-status-bundle.schema.json",
  "title": "PlanningOps Plain Python Compatibility Manifest Status Bundle",
  "type": "object",
  "required": [
    "status_path",
    "status_validation_path",
    "manifest_path",
    "resolved_guardrail_script_paths",
    "ready",
    "next_step",
    "status_verdict",
    "status_validation_verdict",
    "status_report",
    "status_validation_report"
  ],
  "properties": {
    "status_path": {
      "type": "string",
      "minLength": 1
    },
    "status_validation_path": {
      "type": "string",
      "minLength": 1
    },
    "manifest_path": {
      "type": "string",
      "minLength": 1
    },
    "resolved_guardrail_script_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ready": {
      "type": "boolean"
    },
    "next_step": {
      "type": "string",
      "minLength": 1
    },
    "status_verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "status_validation_verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "status_report": {
      "type": "object"
    },
    "status_validation_report": {
      "type": "object"
    },
    "resolved_status_bundle_path": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
