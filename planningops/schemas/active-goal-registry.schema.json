{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rather-not-work-on.dev/planningops/active-goal-registry.schema.json",
  "title": "Active Goal Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_version",
    "active_goal_key",
    "goals"
  ],
  "properties": {
    "registry_version": {
      "type": "integer",
      "const": 1
    },
    "active_goal_key": {
      "type": "string"
    },
    "goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "goal_key",
          "title",
          "status",
          "owner_repo",
          "goal_brief_ref",
          "execution_contract_file",
          "completion_contract_refs",
          "operator_channels"
        ],
        "properties": {
          "goal_key": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "active",
              "blocked",
              "achieved",
              "archived"
            ]
          },
          "owner_repo": {
            "type": "string",
            "minLength": 1
          },
          "goal_brief_ref": {
            "type": "string",
            "minLength": 1
          },
          "execution_contract_file": {
            "type": "string",
            "minLength": 1
          },
          "completion_contract_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "next_goal_key": {
            "type": "string",
            "minLength": 1
          },
          "operator_channels": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "primary_operator_channel",
              "terminal_notification_channel"
            ],
            "properties": {
              "primary_operator_channel": {
                "$ref": "#/$defs/channelRef"
              },
              "terminal_notification_channel": {
                "$ref": "#/$defs/channelRef"
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "channelRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "execution_repo",
        "adapter_contract_ref"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "slack_skill_cli",
            "slack_skill_mcp",
            "email_cli",
            "email_mcp"
          ]
        },
        "execution_repo": {
          "type": "string",
          "minLength": 1
        },
        "adapter_contract_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
