{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "c5-observability-event",
  "title": "C5 Observability Event",
  "type": "object",
  "required": [
    "trace_id",
    "span_id",
    "run_id",
    "event_type",
    "event_time",
    "event_id",
    "sequence_no",
    "delivery_status"
  ],
  "properties": {
    "trace_id": {"type": "string"},
    "span_id": {"type": "string"},
    "run_id": {"type": "string"},
    "event_type": {"type": "string"},
    "event_time": {"type": "string"},
    "event_id": {"type": "string"},
    "sequence_no": {"type": "integer"},
    "delivery_status": {
      "type": "string",
      "enum": ["pending", "delivered", "retriable_failed", "terminal_failed"]
    }
  },
  "additionalProperties": true
}
