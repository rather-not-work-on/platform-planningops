{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MONDAY Agent Harness Projection Status Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status_path",
    "status_validation_path",
    "bundle_path",
    "validation_report_path",
    "mission_id",
    "run_id",
    "session_id",
    "ready",
    "next_step",
    "projection_validation_verdict",
    "projection_validation_state",
    "status_sidecar_validation_verdict",
    "status_report",
    "status_validation_report"
  ],
  "properties": {
    "status_path": { "type": "string", "minLength": 1 },
    "status_validation_path": { "type": "string", "minLength": 1 },
    "bundle_path": { "type": "string", "minLength": 1 },
    "validation_report_path": { "type": "string", "minLength": 1 },
    "mission_id": { "type": ["string", "null"] },
    "run_id": { "type": ["string", "null"] },
    "session_id": { "type": ["string", "null"] },
    "ready": { "type": "boolean" },
    "next_step": { "type": "string", "minLength": 1 },
    "projection_validation_verdict": {
      "type": "string",
      "enum": ["pass", "fail", "missing", "unknown"]
    },
    "projection_validation_state": {
      "type": "string",
      "enum": ["fresh", "stale", "missing"]
    },
    "status_sidecar_validation_verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "status_report": { "type": "object" },
    "status_validation_report": { "type": "object" },
    "resolved_status_bundle_path": { "type": "string", "minLength": 1 }
  }
}
