{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "meta-plan-graph-v1",
  "title": "Meta Plan Graph v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta_plan_graph"
  ],
  "properties": {
    "meta_plan_graph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "meta_plan_id",
        "graph_revision",
        "source_of_truth",
        "initiative",
        "nodes",
        "edges"
      ],
      "properties": {
        "meta_plan_id": {
          "type": "string",
          "minLength": 1
        },
        "graph_revision": {
          "type": "integer",
          "minimum": 1
        },
        "source_of_truth": {
          "type": "string",
          "minLength": 1
        },
        "initiative": {
          "type": "string",
          "minLength": 1
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/node"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/edge"
          }
        },
        "policy": {
          "$ref": "#/$defs/policy"
        }
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "plan_path",
        "execution_order",
        "target_repo",
        "component",
        "workflow_state",
        "loop_profile",
        "status",
        "last_verdict",
        "last_reason"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "plan_path": {
          "type": "string",
          "minLength": 1
        },
        "execution_order": {
          "type": "integer",
          "minimum": 1
        },
        "target_repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "component": {
          "type": "string",
          "enum": [
            "planningops",
            "contracts",
            "provider_gateway",
            "observability_gateway",
            "runtime",
            "orchestrator"
          ]
        },
        "workflow_state": {
          "type": "string",
          "enum": [
            "backlog",
            "ready_contract",
            "ready_implementation",
            "in_progress",
            "review_gate",
            "blocked",
            "done"
          ]
        },
        "loop_profile": {
          "type": "string",
          "enum": [
            "l1_contract_clarification",
            "l2_simulation",
            "l3_implementation_tdd",
            "l4_integration_reconcile",
            "l5_recovery_replan"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "ready",
            "in_progress",
            "review_gate",
            "blocked",
            "replan_required",
            "done"
          ]
        },
        "last_verdict": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "inconclusive",
            "unknown"
          ]
        },
        "last_reason": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "type"
      ],
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "depends_on",
            "blocks",
            "supersedes"
          ]
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wip_limit",
        "strict_dependency_gate",
        "strict_projection_gate"
      ],
      "properties": {
        "wip_limit": {
          "type": "integer",
          "minimum": 1
        },
        "strict_dependency_gate": {
          "type": "boolean"
        },
        "strict_projection_gate": {
          "type": "boolean"
        }
      }
    }
  }
}
