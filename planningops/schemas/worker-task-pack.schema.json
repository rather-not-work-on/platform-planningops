{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "worker-task-pack-v1",
  "title": "Worker Task Pack v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "worker_task_pack"
  ],
  "properties": {
    "worker_task_pack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "task_key",
        "issue_number",
        "mode",
        "loop_profile",
        "runtime_profile",
        "worker_policy_kind",
        "command",
        "retry_policy",
        "timeout_ms",
        "idempotency_key"
      ],
      "properties": {
        "version": {
          "type": "string",
          "enum": [
            "v1"
          ]
        },
        "task_key": {
          "type": "string",
          "minLength": 1
        },
        "issue_number": {
          "type": "integer",
          "minimum": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "dry-run",
            "apply"
          ]
        },
        "loop_profile": {
          "type": "string",
          "minLength": 1
        },
        "runtime_profile": {
          "type": "string",
          "minLength": 1
        },
        "worker_policy_kind": {
          "type": "string",
          "enum": [
            "parser_diff_dry_run",
            "python_script",
            "shell"
          ]
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "retry_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_retries"
          ],
          "properties": {
            "max_retries": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "idempotency_key": {
          "type": "string",
          "minLength": 8
        },
        "target_repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "metadata": {
          "type": "object"
        }
      }
    }
  }
}
